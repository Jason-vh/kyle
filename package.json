{
  "name": "kyle",
  "private": true,
  "type": "module",
  "module": "index.ts",
  "scripts": {
    "dev": "bun run --watch index.ts",
    "db:up": "docker compose -f docker-compose.dev.yml up -d",
    "db:down": "docker compose -f docker-compose.dev.yml down",
    "db:generate": "bunx drizzle-kit generate",
    "db:migrate": "bun run server/db/migrate.ts",
    "db:studio": "bunx drizzle-kit studio",
    "cli": "bun run cli.ts",
    "fmt": "oxfmt .",
    "fmt:check": "oxfmt --check .",
    "lint": "oxlint .",
    "check": "bun run fmt:check && oxlint . && bunx tsc --noEmit -p tsconfig.server.json",
    "dev:web": "cd web && bun run dev",
    "build:web": "cd web && bun run build"
  },
  "dependencies": {
    "@mariozechner/pi-agent-core": "^0.52.8",
    "@mariozechner/pi-ai": "^0.52.8",
    "@slack/web-api": "^7.14.0",
    "discord.js": "^14.25.1",
    "drizzle-orm": "^0.43.1",
    "postgres": "^3.4.7"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "drizzle-kit": "^0.31.1",
    "lefthook": "^2.1.1",
    "oxfmt": "^0.35.0",
    "oxlint": "^1.50.0"
  },
  "peerDependencies": {
    "typescript": "^5"
  }
}
